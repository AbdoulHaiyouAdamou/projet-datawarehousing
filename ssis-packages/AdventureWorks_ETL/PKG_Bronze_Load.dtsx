<?xml version="1.0"?>
<DTS:Executable xmlns:DTS="www.microsoft.com/SqlServer/Dts"
  DTS:refId="Package"
  DTS:CreationDate="5/17/2026 4:30:00 PM"
  DTS:CreatorComputerName="ABDOUL"
  DTS:CreatorName="ABDOUL\Dell"
  DTS:DTSID="{A1B2C3D4-1111-1111-1111-000000000001}"
  DTS:ExecutableType="Microsoft.Package"
  DTS:LocaleID="1036"
  DTS:ObjectName="PKG_Bronze_Load"
  DTS:PackageType="5"
  DTS:VersionBuild="1"
  DTS:VersionGUID="{A1B2C3D4-1111-1111-1111-000000000002}">
  <DTS:Property DTS:Name="PackageFormatVersion">8</DTS:Property>

  <DTS:ConnectionManagers>
    <DTS:ConnectionManager
      DTS:refId="Package.ConnectionManagers[DW_AdventureWorks]"
      DTS:CreationName="OLEDB"
      DTS:DTSID="{A1B2C3D4-1111-2222-0001-000000000001}"
      DTS:ObjectName="DW_AdventureWorks">
      <DTS:ObjectData>
        <DTS:ConnectionManager
          DTS:ConnectionString="Data Source=localhost;Initial Catalog=AdventureWorks_DW;Provider=MSOLEDBSQL;Integrated Security=SSPI;Auto Translate=False;" />
      </DTS:ObjectData>
    </DTS:ConnectionManager>
    <DTS:ConnectionManager
      DTS:refId="Package.ConnectionManagers[SRC_AdventureWorks]"
      DTS:CreationName="OLEDB"
      DTS:DTSID="{A1B2C3D4-1111-2222-0001-000000000002}"
      DTS:ObjectName="SRC_AdventureWorks">
      <DTS:ObjectData>
        <DTS:ConnectionManager
          DTS:ConnectionString="Data Source=localhost;Initial Catalog=AdventureWorks2022;Provider=MSOLEDBSQL;Integrated Security=SSPI;Auto Translate=False;" />
      </DTS:ObjectData>
    </DTS:ConnectionManager>
  </DTS:ConnectionManagers>

  <DTS:Variables />

  <DTS:Executables>
    <!-- TASK 1 : Truncate toutes les tables Bronze -->
    <DTS:Executable
      DTS:refId="Package\Truncate Bronze Tables"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{A1B2C3D4-1111-3333-0001-000000000001}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Truncate Bronze Tables"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
          SQLTask:Connection="DW_AdventureWorks"
          SQLTask:SqlStatementSource="
TRUNCATE TABLE bronze.SalesOrderHeader;
TRUNCATE TABLE bronze.SalesOrderDetail;
TRUNCATE TABLE bronze.Product;
TRUNCATE TABLE bronze.ProductCategory;
TRUNCATE TABLE bronze.ProductSubcategory;
TRUNCATE TABLE bronze.Customer;
TRUNCATE TABLE bronze.Person;
TRUNCATE TABLE bronze.EmailAddress;
TRUNCATE TABLE bronze.Address;
TRUNCATE TABLE bronze.StateProvince;
TRUNCATE TABLE bronze.CountryRegion;
TRUNCATE TABLE bronze.SalesTerritory;
TRUNCATE TABLE bronze.SpecialOffer;
TRUNCATE TABLE bronze.SpecialOfferProduct;
TRUNCATE TABLE bronze.Store;
" />
      </DTS:ObjectData>
    </DTS:Executable>

    <!-- TASK 2 : Load Sales Tables -->
    <DTS:Executable
      DTS:refId="Package\Load Sales Tables"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{A1B2C3D4-1111-3333-0001-000000000002}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load Sales Tables"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
          SQLTask:Connection="DW_AdventureWorks"
          SQLTask:SqlStatementSource="
INSERT INTO bronze.SalesOrderHeader
(SalesOrderID,RevisionNumber,OrderDate,DueDate,ShipDate,[Status],OnlineOrderFlag,SalesOrderNumber,PurchaseOrderNumber,AccountNumber,CustomerID,SalesPersonID,TerritoryID,BillToAddressID,ShipToAddressID,ShipMethodID,CreditCardID,CreditCardApprovalCode,CurrencyRateID,SubTotal,TaxAmt,Freight,TotalDue,Comment,ModifiedDate)
SELECT SalesOrderID,RevisionNumber,OrderDate,DueDate,ShipDate,[Status],OnlineOrderFlag,SalesOrderNumber,PurchaseOrderNumber,AccountNumber,CustomerID,SalesPersonID,TerritoryID,BillToAddressID,ShipToAddressID,ShipMethodID,CreditCardID,CreditCardApprovalCode,CurrencyRateID,SubTotal,TaxAmt,Freight,TotalDue,Comment,ModifiedDate
FROM [AdventureWorks2022].Sales.SalesOrderHeader;

INSERT INTO bronze.SalesOrderDetail
(SalesOrderID,SalesOrderDetailID,CarrierTrackingNumber,OrderQty,ProductID,SpecialOfferID,UnitPrice,UnitPriceDiscount,LineTotal,ModifiedDate)
SELECT SalesOrderID,SalesOrderDetailID,CarrierTrackingNumber,OrderQty,ProductID,SpecialOfferID,UnitPrice,UnitPriceDiscount,LineTotal,ModifiedDate
FROM [AdventureWorks2022].Sales.SalesOrderDetail;
" />
      </DTS:ObjectData>
    </DTS:Executable>

    <!-- TASK 3 : Load Product Tables -->
    <DTS:Executable
      DTS:refId="Package\Load Product Tables"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{A1B2C3D4-1111-3333-0001-000000000003}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load Product Tables"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
          SQLTask:Connection="DW_AdventureWorks"
          SQLTask:SqlStatementSource="
INSERT INTO bronze.Product
(ProductID,Name,ProductNumber,MakeFlag,FinishedGoodsFlag,Color,SafetyStockLevel,ReorderPoint,StandardCost,ListPrice,Size,SizeUnitMeasureCode,WeightUnitMeasureCode,Weight,DaysToManufacture,ProductLine,Class,Style,ProductSubcategoryID,ProductModelID,SellStartDate,SellEndDate,DiscontinuedDate,ModifiedDate)
SELECT ProductID,Name,ProductNumber,MakeFlag,FinishedGoodsFlag,Color,SafetyStockLevel,ReorderPoint,StandardCost,ListPrice,Size,SizeUnitMeasureCode,WeightUnitMeasureCode,Weight,DaysToManufacture,ProductLine,Class,Style,ProductSubcategoryID,ProductModelID,SellStartDate,SellEndDate,DiscontinuedDate,ModifiedDate
FROM [AdventureWorks2022].Production.Product;

INSERT INTO bronze.ProductCategory (ProductCategoryID,Name,ModifiedDate)
SELECT ProductCategoryID,Name,ModifiedDate FROM [AdventureWorks2022].Production.ProductCategory;

INSERT INTO bronze.ProductSubcategory (ProductSubcategoryID,ProductCategoryID,Name,ModifiedDate)
SELECT ProductSubcategoryID,ProductCategoryID,Name,ModifiedDate FROM [AdventureWorks2022].Production.ProductSubcategory;
" />
      </DTS:ObjectData>
    </DTS:Executable>

    <!-- TASK 4 : Load Customer Tables -->
    <DTS:Executable
      DTS:refId="Package\Load Customer Tables"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{A1B2C3D4-1111-3333-0001-000000000004}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load Customer Tables"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
          SQLTask:Connection="DW_AdventureWorks"
          SQLTask:SqlStatementSource="
INSERT INTO bronze.Customer (CustomerID,PersonID,StoreID,TerritoryID,AccountNumber,ModifiedDate)
SELECT CustomerID,PersonID,StoreID,TerritoryID,AccountNumber,ModifiedDate FROM [AdventureWorks2022].Sales.Customer;

INSERT INTO bronze.Person (BusinessEntityID,PersonType,Title,FirstName,MiddleName,LastName,Suffix,EmailPromotion,ModifiedDate)
SELECT BusinessEntityID,PersonType,Title,FirstName,MiddleName,LastName,Suffix,EmailPromotion,ModifiedDate FROM [AdventureWorks2022].Person.Person;

INSERT INTO bronze.EmailAddress (BusinessEntityID,EmailAddressID,EmailAddress,ModifiedDate)
SELECT BusinessEntityID,EmailAddressID,EmailAddress,ModifiedDate FROM [AdventureWorks2022].Person.EmailAddress;

INSERT INTO bronze.Store (BusinessEntityID,Name,SalesPersonID,ModifiedDate)
SELECT BusinessEntityID,Name,SalesPersonID,ModifiedDate FROM [AdventureWorks2022].Sales.Store;
" />
      </DTS:ObjectData>
    </DTS:Executable>

    <!-- TASK 5 : Load Geography Tables -->
    <DTS:Executable
      DTS:refId="Package\Load Geography Tables"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{A1B2C3D4-1111-3333-0001-000000000005}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load Geography Tables"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
          SQLTask:Connection="DW_AdventureWorks"
          SQLTask:SqlStatementSource="
INSERT INTO bronze.Address (AddressID,AddressLine1,AddressLine2,City,StateProvinceID,PostalCode,ModifiedDate)
SELECT AddressID,AddressLine1,AddressLine2,City,StateProvinceID,PostalCode,ModifiedDate FROM [AdventureWorks2022].Person.[Address];

INSERT INTO bronze.StateProvince (StateProvinceID,StateProvinceCode,CountryRegionCode,Name,TerritoryID,ModifiedDate)
SELECT StateProvinceID,StateProvinceCode,CountryRegionCode,Name,TerritoryID,ModifiedDate FROM [AdventureWorks2022].Person.StateProvince;

INSERT INTO bronze.CountryRegion (CountryRegionCode,Name,ModifiedDate)
SELECT CountryRegionCode,Name,ModifiedDate FROM [AdventureWorks2022].Person.CountryRegion;

INSERT INTO bronze.SalesTerritory (TerritoryID,Name,CountryRegionCode,[Group],SalesYTD,SalesLastYear,CostYTD,CostLastYear,ModifiedDate)
SELECT TerritoryID,Name,CountryRegionCode,[Group],SalesYTD,SalesLastYear,CostYTD,CostLastYear,ModifiedDate FROM [AdventureWorks2022].Sales.SalesTerritory;

INSERT INTO bronze.SpecialOffer (SpecialOfferID,Description,DiscountPct,Type,Category,StartDate,EndDate,MinQty,MaxQty,ModifiedDate)
SELECT SpecialOfferID,Description,DiscountPct,Type,Category,StartDate,EndDate,MinQty,MaxQty,ModifiedDate FROM [AdventureWorks2022].Sales.SpecialOffer;

INSERT INTO bronze.SpecialOfferProduct (SpecialOfferID,ProductID,ModifiedDate)
SELECT SpecialOfferID,ProductID,ModifiedDate FROM [AdventureWorks2022].Sales.SpecialOfferProduct;
" />
      </DTS:ObjectData>
    </DTS:Executable>

    <!-- TASK 6 : Log Bronze Load -->
    <DTS:Executable
      DTS:refId="Package\Log Bronze Success"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{A1B2C3D4-1111-3333-0001-000000000006}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Log Bronze Success"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask"
          SQLTask:Connection="DW_AdventureWorks"
          SQLTask:SqlStatementSource="
INSERT INTO dbo.ETL_LoadLog (LayerName, TableName, RowsInserted, Status, EndTime)
SELECT 'Bronze', 'All Tables',
  (SELECT SUM(p.rows) FROM sys.partitions p JOIN sys.tables t ON p.object_id=t.object_id JOIN sys.schemas s ON t.schema_id=s.schema_id WHERE s.name='bronze' AND p.index_id IN (0,1)),
  'Success', SYSDATETIME();
" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>

  <DTS:PrecedenceConstraints>
    <DTS:PrecedenceConstraint DTS:refId="Package.PrecedenceConstraints[C1]" DTS:CreationName="" DTS:DTSID="{A1B2C3D4-1111-4444-0001-000000000001}" DTS:From="Package\Truncate Bronze Tables" DTS:LogicalAnd="True" DTS:ObjectName="C1" DTS:To="Package\Load Sales Tables" />
    <DTS:PrecedenceConstraint DTS:refId="Package.PrecedenceConstraints[C2]" DTS:CreationName="" DTS:DTSID="{A1B2C3D4-1111-4444-0001-000000000002}" DTS:From="Package\Truncate Bronze Tables" DTS:LogicalAnd="True" DTS:ObjectName="C2" DTS:To="Package\Load Product Tables" />
    <DTS:PrecedenceConstraint DTS:refId="Package.PrecedenceConstraints[C3]" DTS:CreationName="" DTS:DTSID="{A1B2C3D4-1111-4444-0001-000000000003}" DTS:From="Package\Truncate Bronze Tables" DTS:LogicalAnd="True" DTS:ObjectName="C3" DTS:To="Package\Load Customer Tables" />
    <DTS:PrecedenceConstraint DTS:refId="Package.PrecedenceConstraints[C4]" DTS:CreationName="" DTS:DTSID="{A1B2C3D4-1111-4444-0001-000000000004}" DTS:From="Package\Truncate Bronze Tables" DTS:LogicalAnd="True" DTS:ObjectName="C4" DTS:To="Package\Load Geography Tables" />
    <DTS:PrecedenceConstraint DTS:refId="Package.PrecedenceConstraints[C5]" DTS:CreationName="" DTS:DTSID="{A1B2C3D4-1111-4444-0001-000000000005}" DTS:From="Package\Load Sales Tables" DTS:LogicalAnd="True" DTS:ObjectName="C5" DTS:To="Package\Log Bronze Success" />
    <DTS:PrecedenceConstraint DTS:refId="Package.PrecedenceConstraints[C6]" DTS:CreationName="" DTS:DTSID="{A1B2C3D4-1111-4444-0001-000000000006}" DTS:From="Package\Load Product Tables" DTS:LogicalAnd="True" DTS:ObjectName="C6" DTS:To="Package\Log Bronze Success" />
    <DTS:PrecedenceConstraint DTS:refId="Package.PrecedenceConstraints[C7]" DTS:CreationName="" DTS:DTSID="{A1B2C3D4-1111-4444-0001-000000000007}" DTS:From="Package\Load Customer Tables" DTS:LogicalAnd="True" DTS:ObjectName="C7" DTS:To="Package\Log Bronze Success" />
    <DTS:PrecedenceConstraint DTS:refId="Package.PrecedenceConstraints[C8]" DTS:CreationName="" DTS:DTSID="{A1B2C3D4-1111-4444-0001-000000000008}" DTS:From="Package\Load Geography Tables" DTS:LogicalAnd="True" DTS:ObjectName="C8" DTS:To="Package\Log Bronze Success" />
  </DTS:PrecedenceConstraints>
</DTS:Executable>


